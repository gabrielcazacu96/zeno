{
  "name": "@zeno/layouts",
  "version": "0.0.0",
  "exports": {
    "./style.css": "./src/style.css",
    "./core": "./src/core.ts",
    "./ui": "./src/ui.ts",
    "./blog/*": "./src/blog/*.tsx",
    "./404/*": [
      "./src/404/*.ts",
      "./src/404/*.tsx"
    ]
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@zeno/ui": "workspace:*",
    "fumadocs-core": "15.6.6",
    "fumadocs-mdx": "11.7.1",
    "fumadocs-ui": "15.6.6"
  },
  "devDependencies": {
    "@types/mdx": "2.0.13",
    "@types/react": "19.1.8",
    "@zeno/eslint-config": "workspace:*",
    "@zeno/typescript-config": "workspace:*",
    "eslint": "9.32.0"
  }
}
