    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.14.0",
    "next-themes": "^0.4.6",
    "react-day-picker": "^9.14.0",
    "react-hook-form": "^7.75.0",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
