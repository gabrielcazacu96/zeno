{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["NODE_ENV"],
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "types:check": {
      "dependsOn": ["^types:check"]
    },
    "e2e": {
      "dependsOn": ["^build", "@resolve/e2e#verify-deps"],
      "outputs": [
        "./packages/e2e/playwright-report/**",
        "./packages/e2e/test-results/**"
      ],
      "passThroughEnv": ["PLAYWRIGHT_*"]
    },
    "verify-deps": {
      "cache": false
    },
    "e2e:watch": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build", "lint"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    }
  }
}
